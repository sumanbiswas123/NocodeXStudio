{
  "applicationId": "js.neutralino.nocodexstudio",
  "version": "1.0.5",
  "defaultMode": "window",
  "documentRoot": "/dist",
  "url": "/index.html",
  "enableServer": true,
  "enableExtensions": true,
  "singlePageServe": true,
  "enableNativeAPI": true,
  "tokenSecurity": "none",
  "allowedOrigins": [
    "http://localhost:3000"
  ],
  "nativeBlockList": [],
  "nativeAllowList": [
    "app.*",
    "os.*",
    "filesystem.*",
    "window.*",
    "events.*",
    "debug.*",
    "server.*",
    "extensions.*"
  ],
  "extensions": [
    {
      "id": "js.neutralino.nocodex.sidecar",
      "commandWindows": "\"${NL_PATH}\\native\\cdp_bridge.exe\" --cdp-port 9222"
    }
  ],
  "modes": {
    "window": {
      "title": "Nocode X Studio",
      "width": 1280,
      "height": 800,
      "minWidth": 800,
      "minHeight": 600,
      "center": true,
      "fullScreen": false,
      "alwaysOnTop": false,
      "enableInspector": true,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "extendUserAgentWith": "Neutralinojs"
    }
  },
  "cli": {
    "binaryName": "nocode-x-studio",
    "resourcesPath": "/dist",
    "distributionPath": "/dist",
    "copyItems": [
      "native/cdp_bridge.exe"
    ],
    "binaryVersion": "6.5.0",
    "clientVersion": "6.5.0"
  }
}
