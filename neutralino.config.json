{
  "applicationId": "js.neutralino.nocodexstudio",
  "version": "1.0.0",
  "defaultMode": "window",
  "documentRoot": "/dist",
  "url": "/index.html",
  "enableServer": true,
  "singlePageServe": true,
  "enableNativeAPI": true,
  "tokenSecurity": "none",
  "allowedOrigins": ["http://localhost:3000"],
  "nativeBlockList": [],
  "nativeAllowList": [
    "app.*",
    "os.*",
    "filesystem.*",
    "window.*",
    "events.*",
    "debug.*",
    "server.*"
  ],
  "modes": {
    "window": {
      "title": "Nocode X Studio",
      "width": 1280,
      "height": 800,
      "minWidth": 800,
      "minHeight": 600,
      "center": true,
      "fullScreen": false,
      "alwaysOnTop": false,
      "enableInspector": true,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "extendUserAgentWith": "Neutralinojs"
    }
  },
  "cli": {
    "binaryName": "nocode-x-studio",
    "resourcesPath": "/dist",
    "distributionPath": "/dist",
    "binaryVersion": "6.5.0",
    "clientVersion": "6.5.0"
  }
}
